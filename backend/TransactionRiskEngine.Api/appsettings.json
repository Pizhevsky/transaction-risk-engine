{
  "ConnectionStrings": {
    "RiskDb": "Host=localhost;Port=5432;Database=transaction_risk;Username=postgres;Password=postgres"
  },
  "SeedData": {
    "Enabled": true
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://127.0.0.1:4200"
    ]
  },
  "Database": {
    "UseMigrations": true
  },
  "RateLimiting": {
    "WritePermitLimit": 120
  },
  "Outbox": {
    "Enabled": true,
    "PollIntervalSeconds": 10,
    "BatchSize": 25,
    "MaxAttempts": 5,
    "LockTimeoutSeconds": 120,
    "Publisher": {
      "HttpEndpoint": null,
      "LogPublishedMessages": true
    }
  },
  "RiskRules": {
    "CacheSeconds": 30
  },
  "GraphRisk": {
    "MaxDepth": 3,
    "MaxPaths": 3,
    "CacheSeconds": 10,
    "MaxEdgesPerExpansion": 500,
    "MaxTotalNodes": 1000
  },
  "RiskEvaluation": {
    "DefaultBatchSize": 250
  }
}
