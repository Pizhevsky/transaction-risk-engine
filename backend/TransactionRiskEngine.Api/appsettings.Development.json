{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://127.0.0.1:4200"
    ]
  },
  "Database": {
    "UseMigrations": true
  },
  "RateLimiting": {
    "WritePermitLimit": 120
  },
  "Outbox": {
    "Enabled": true,
    "PollIntervalSeconds": 10,
    "BatchSize": 25,
    "MaxAttempts": 5,
    "LockTimeoutSeconds": 120
  },
  "RiskEvaluation": {
    "DefaultBatchSize": 250
  }
}
