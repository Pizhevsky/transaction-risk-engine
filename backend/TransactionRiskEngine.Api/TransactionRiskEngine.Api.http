@host = http://localhost:5176
@alex = 11111111-1111-1111-1111-111111111111

GET {{host}}/

### Users
GET {{host}}/api/users

### Transactions
GET {{host}}/api/transactions?riskLevel=review

### Analyse risky transaction
POST {{host}}/api/transactions/analyse
Content-Type: application/json

{
  "userId": "{{alex}}",
  "amount": 1250,
  "currency": "NZD",
  "merchant": "Online Electronics Store",
  "cardFingerprint": "card-shared-risk-001",
  "cardLast4": "4242",
  "deviceFingerprint": "device-shared-risk-001",
  "ipAddress": "203.0.113.99",
  "successful": true
}

### Graph
GET {{host}}/api/users/{{alex}}/connections

### Rules
GET {{host}}/api/rules

### Update rule
PUT {{host}}/api/rules/HIGH_AMOUNT
Content-Type: application/json

{
  "description": "Transaction amount is materially above user history.",
  "weight": 35,
  "enabled": true
}

### Evaluate recent transactions
POST {{host}}/api/rules/evaluate
Content-Type: application/json

{
  "batchSize": 250,
  "reason": "Rule tuning test"
}

### Health readiness
GET {{host}}/health/ready
